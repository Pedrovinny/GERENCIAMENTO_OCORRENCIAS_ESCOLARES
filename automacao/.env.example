# Copie este arquivo para "automacao/.env" e preencha com as credenciais reais
# do Mailtrap. Nunca commite o arquivo .env real.
#
# Usa a Mailtrap Send API (produção — send.api.mailtrap.io), autenticada por
# Bearer token. O e-mail em MAILTRAP_FROM_EMAIL precisa pertencer a um
# Sending Domain já verificado no painel do Mailtrap.

MAILTRAP_API_TOKEN=changeme
MAILTRAP_API_URL=https://send.api.mailtrap.io/api/send

MAILTRAP_FROM_EMAIL=no-reply@seu-dominio-verificado.com
MAILTRAP_FROM_NAME=Ocorrencias Escolares - IFAM Humaita
